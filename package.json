{
  "name": "eric-friday-portfolio",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "pnpm --filter @portfolio/web dev",
    "build": "pnpm --filter @portfolio/web build",
    "preview": "pnpm --filter @portfolio/web preview",
    "deploy": "pnpm --filter @portfolio/web deploy",
    "typecheck": "pnpm -r typecheck",
    "cf-typegen": "pnpm --filter @portfolio/web cf-typegen"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
